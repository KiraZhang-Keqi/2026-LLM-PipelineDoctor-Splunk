# ── Pipeline Doctor 配置模板 ──
# 复制本文件为 .env 并填入真实值：  cp .env.example .env
# .env 已被 .gitignore 忽略，不会提交到仓库。请勿把真实密钥写进 .env.example。

# Anthropic API key（agent.py 用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Splunk HEC token（generate_data.py 灌数据用）
PIPELINE_HEC_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Splunk HEC 主机 IP（generate_data.py 用，只写 IP，不带 https/端口）
SPLUNK_HEC_HOST=100.119.17.40

# Splunk REST 接口（agent.py 用，带 https 和 8089 端口）
SPLUNK_HOST=https://100.119.17.40:8089

# Splunk 登录用户名 / 密码（agent.py 查询用）
SPLUNK_USERNAME=kiraa
# 密码留空则运行时会提示输入；填了就免输入
SPLUNK_PASSWORD=
